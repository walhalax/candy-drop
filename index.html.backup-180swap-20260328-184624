      return true;
    }

    // Check satellite collision during rotation and return push direction (dx, dy) to avoid overlap
    // Returns null if no collision, or { dx, dy, valid } where valid means the push would actually work
    function getSatelliteCollisionPush(x, y, rot) {
      const [ox, oy] = ROT_OFFSETS[rot];
      const sx = x + ox;
      const sy = y + oy;
      // Check if satellite would be in a blocked cell
      if (sx >= 0 && sx < COLS && sy >= 0 && sy < ROWS) {
        if (board[sy][sx] !== null) {
          // Satellite would collide - determine push direction
          // Push away from the obstacle (toward main block)
          let pushX = 0, pushY = 0;
          if (ox !== 0) pushX = -Math.sign(ox); // Push opposite to satellite offset
          if (oy !== 0) pushY = -Math.sign(oy); // Push opposite to satellite offset
          // If push direction is zero (edge case), use perpendicular push
          if (pushX === 0 && pushY === 0) {
            // For vertical satellite (ox=0), push horizontally
            pushX = (oy > 0) ? -1 : 1;
          }
          // Check if pushed position is valid for main block AND satellite doesn't collide there
          const pushedSX = x + pushX + ox;
          const pushedSY = y + pushY + oy;
          const mainValid = canPlaceCell(x + pushX, y + pushY);
          const satValid = (pushedSX < 0 || pushedSX >= COLS || pushedSY < 0 || pushedSY >= ROWS || board[pushedSY][pushedSX] === null);
          if (mainValid && satValid) {
            return { dx: pushX, dy: pushY };
          }
          // Try alternative push directions
          const alternatives = [];
          if (pushX !== 0) alternatives.push({ dx: 0, dy: pushY || 1 }, { dx: 0, dy: pushY || -1 });
          if (pushY !== 0) alternatives.push({ dx: pushX || 1, dy: 0 }, { dx: pushX || -1, dy: 0 });
          for (const alt of alternatives) {
            const altSX = x + alt.dx + ox;
            const altSY = y + alt.dy + oy;
            const altMainValid = canPlaceCell(x + alt.dx, y + alt.dy);
            const altSatValid = (altSX < 0 || altSX >= COLS || altSY < 0 || altSY >= ROWS || board[altSY][altSX] === null);
            if (altMainValid && altSatValid) {
              return alt;
            }
          }
        }
      }
      return null; // No collision or push not possible
    }

    // Check if rotation would leave satellite embedded and uncorrectable
    function canRotateWithCorrection(x, y, rot) {
      const [ox, oy] = ROT_OFFSETS[rot];
      const spX = x + ox;
      const spY = y + oy;

      // Check if satellite would be inside a block
      if (spX >= 0 && spX < COLS && spY >= 0 && spY < ROWS) {
        if (board[spY][spX] !== null) {
          // Satellite would be embedded - check if we can correct it

          // Special case: if satellite is below main (oy > 0) and there's space below main,
          // allow rotation - this enables "position swap" rotation
          if (oy > 0 && canPlaceCell(x, y + 1)) {
            return true; // Space below main block - allow rotation
          }

          let pushX = 0, pushY = 0;
          if (ox !== 0) pushX = -Math.sign(ox);
          if (oy !== 0) pushY = -Math.sign(oy);
          if (pushX === 0 && pushY === 0) pushX = 1;

          const attempts = [
            { dx: pushX, dy: pushY },
            { dx: pushX, dy: 0 },
            { dx: 0, dy: pushY },
            { dx: -pushX, dy: pushY },
            { dx: pushX, dy: -pushY },
            { dx: 0, dy: 1 },
            { dx: 0, dy: -pushY },
            { dx: 1, dy: 0 },
            { dx: -1, dy: 0 },
          ];

          for (const attempt of attempts) {
            const newX = x + attempt.dx;
            const newY = y + attempt.dy;
            const newSp = { x: newX + ox, y: newY + oy };

            if (!canPlaceCell(newX, newY)) continue;
            if (newSp.x >= 0 && newSp.x < COLS && newSp.y >= 0 && newSp.y < ROWS) {
              if (board[newSp.y][newSp.x] !== null) continue;
            }
            // Correction possible
            return true;
          }
          // No correction possible - rotation would leave satellite embedded
          return false;
        }
      }
      return true; // No collision
    }

    function canSpawnPuyo(x, y, rot) {
      // Stricter check for initial spawn position
      if (!canPlaceCell(x, y)) return false;
      const [ox, oy] = ROT_OFFSETS[rot];
      if (!canPlaceCell(x + ox, y + oy)) return false;
