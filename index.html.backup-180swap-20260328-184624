<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <!-- iOS Safari Optimized Viewport -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <!-- iOS Web App Meta -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="CandyDrop">
  <!-- iOS Touch Optimization -->
  <meta name="format-detection" content="telephone=no">
  <meta name="mobile-web-app-capable" content="yes">
  <title>[Game]Candy-Drops</title>
  <style>
    /* iOS Safe Area Support */
    html, body {
      margin: 0;
      padding: 0;
      padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
      /* Prevent pull-to-refresh and rubber-banding */
      overscroll-behavior: none;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      user-select: none;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: linear-gradient(135deg, #ffd6e7 0%, #ffb6d9 25%, #ffc8dd 50%, #ffe0f0 75%, #ffd6e7 100%);
      background-size: 400% 400%;
      animation: bgShimmer 8s ease infinite;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      min-height: 100dvh;
      font-family: 'Courier New', monospace;
      overflow: hidden;
      position: fixed;
      inset: 0;
    }
    @keyframes bgShimmer {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    #game-container {
      position: relative;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    #game-area {
      position: relative;
      display: flex;
      flex-direction: row;
      align-items: flex-start;
    }
    #game-area {
      background: rgba(255,245,248,0.95);
      border-radius: 12px;
      padding: 8px;
    }
    canvas {
      display: block;
      border: 3px solid #ff69b4;
      box-shadow: 0 0 30px rgba(255, 105, 180, 0.5);
      /* Crisp rendering on iOS */
      image-rendering: -webkit-optimize-contrast;
      image-rendering: crisp-edges;
    }
    #ui {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: #333;
      font-size: 18px;
      font-weight: bold;
      padding: 0 4px;
    }
    #score { color: #ff1493; }
    #chain { color: #ff69b4; }
    #next-container {
      position: absolute;
      top: 0;
      left: calc(100% + 10px);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      color: #333;
      font-size: 14px;
      font-weight: bold;
    }
    #next-container canvas {
      border: 2px solid #ff69b4;
      box-shadow: 0 0 15px rgba(255, 105, 180, 0.3);
    }
    #controls {
      width: 100%;
      text-align: center;
      color: #555;
      font-size: 12px;
      background: rgba(255,255,255,0.8);
      padding: 8px 15px;
      border-radius: 8px;
      margin-top: 4px;
    }
    #controls span { margin: 0 8px; }
    #controls .key {
      background: #ffe0f0;
      border: 1px solid #ff69b4;
      border-radius: 4px;
      padding: 2px 6px;
      font-weight: bold;
      color: #ff1493;
    }
    /* iPad Touch Controls - Bottom Right */
    #touch-controls {
      position: fixed;
      bottom: 20px;
      right: 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 12px;
      background: rgba(255, 255, 255, 0.85);
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(255, 105, 180, 0.3);
      z-index: 100;
      /* iOS blur effect */
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .control-row {
      display: flex;
      gap: 8px;
      justify-content: center;
    }
    .touch-btn {
      width: 56px;
      height: 56px;
      border: none;
      border-radius: 14px;
      background: linear-gradient(145deg, #fff0f5, #ffe0ec);
      box-shadow:
        0 2px 8px rgba(255, 105, 180, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.8);
      font-size: 24px;
      color: #ff1493;
      cursor: pointer;
      /* iOS touch feedback */
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      user-select: none;
      transition: transform 0.1s ease, box-shadow 0.1s ease;
    }
    .touch-btn:active {
      transform: scale(0.92);
      background: linear-gradient(145deg, #ffe0ec, #ffd0e0);
      box-shadow:
        0 1px 4px rgba(255, 105, 180, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.5);
    }
    .drop-btn {
      width: 120px;
      background: linear-gradient(145deg, #ffb6d9, #ff8fcc);
      color: #fff;
      font-size: 20px;
      font-weight: bold;
    }
    .drop-btn:active {
      background: linear-gradient(145deg, #ff8fcc, #ff6bb8);
    }
    /* Hide on desktop - show only on touch devices */
    @media (hover: hover) and (pointer: fine) {
      #touch-controls {
        display: none;
      }
    }
    #overlay {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(135deg,
        rgba(255,182,193,0.85) 0%,
        rgba(255,240,245,0.90) 30%,
        rgba(255,230,240,0.88) 70%,
        rgba(255,200,220,0.85) 100%);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      color: #333;
      z-index: 200;
      padding: 20px;
      overflow-y: auto;
    }
    #candy-bg {
      position: fixed;
      top: -50%; left: -50%;
      width: 200%; height: 200%;
      z-index: 199;
      pointer-events: none;
    }
    #overlay.hidden { display: none; }
    #overlay.hidden ~ #candy-bg { z-index: -1; }
    #overlay h1 {
      font-size: 36px;
      margin-bottom: 20px;
      background: linear-gradient(90deg, #ff0000, #ff8800, #ffff00, #00ff00, #0088ff, #8800ff, #ff0088);
      background-size: 200% 100%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: rainbowShift 3s ease infinite;
    }
    @keyframes rainbowShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    #overlay p { margin: 8px 0; color: #555; font-size: 14px; }
    #overlay .key {
      background: #ffe0f0;
      border: 1px solid #ff69b4;
      border-radius: 4px;
      padding: 2px 8px;
      font-weight: bold;
      color: #ff1493;
      display: inline-block;
      min-width: 24px;
      text-align: center;
    }
    #overlay .start-hint {
      margin-top: 30px;
      color: #ff1493;
      font-weight: bold;
      font-size: 20px;
      animation: pulse 1.5s infinite;
    }
    .start-btn {
      margin-top: 25px;
      padding: 15px 40px;
      font-size: 20px;
      font-weight: bold;
      color: #fff;
      background: linear-gradient(145deg, #ff69b4, #ff1493);
      border: none;
      border-radius: 30px;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(255, 105, 180, 0.5);
      animation: pulse 1.5s infinite;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      user-select: none;
      min-width: 200px;
    }
    .start-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 25px rgba(255, 105, 180, 0.6);
    }
    .start-btn:active {
      transform: scale(0.98);
    }
    .restart-btn, .title-btn {
      display: none;
      position: fixed;
      left: 50%;
      transform: translateX(-50%);
      padding: 15px 40px;
      font-size: 18px;
      font-weight: bold;
      color: #fff;
      background: linear-gradient(145deg, #ff69b4, #ff1493);
      border: none;
      border-radius: 30px;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(255, 105, 180, 0.5);
      z-index: 150;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      user-select: none;
    }
    .restart-btn {
      top: calc(50% + 60px);
    }
    .title-btn {
      top: calc(50% + 130px);
      background: linear-gradient(145deg, #888888, #666666);
    }
    .restart-btn:active {
      transform: translateX(-50%) scale(0.98);
    }
    .title-btn:active {
      transform: translateX(-50%) scale(0.98);
    }
    #overlay .control-group {
      margin: 12px 0;
      text-align: left;
      min-width: 280px;
    }
    #overlay .control-group h3 {
      color: #ff1493;
      margin-bottom: 8px;
      font-size: 14px;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    /* Difficulty Selection */
    #difficulty-select {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 15px 0;
      align-items: center;
    }
    .diff-btn {
      padding: 10px 20px;
      border: 2px solid #ff69b4;
      border-radius: 20px;
      background: #fff0f5;
      color: #ff1493;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s ease;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      user-select: none;
      min-width: 180px;
    }
    .diff-btn:hover {
      background: #ffe0ec;
      transform: scale(1.05);
    }
    .diff-btn.selected {
      background: linear-gradient(145deg, #ff69b4, #ff1493);
      color: #fff;
      box-shadow: 0 4px 15px rgba(255, 105, 180, 0.4);
    }
    .diff-desc {
      font-size: 11px;
      color: #888;
      margin-top: 3px;
    }
  </style>
</head>
<body>
  <canvas id="candy-bg"></canvas>
  <div id="game-container">
    <div id="ui">
      <div id="score">スコア: <span>0</span></div>
      <div id="chain">連続消し回数: <span>0</span></div>
      <button id="mute-btn" style="background:none;border:none;cursor:pointer;font-size:20px;padding:0 5px;" title="ミュート切替 (M)">🔊</button>
    </div>
    <div id="game-area">
      <canvas id="board"></canvas>
      <div id="next-container">
        <div>次のブロック</div>
        <canvas id="next" width="80" height="80"></canvas>
      </div>
    </div>
    <div id="overlay">
      <h1>Candy Drops</h1>
      <div id="difficulty-select">
        <button class="diff-btn selected" data-diff="easy">
          ふつう
          <div class="diff-desc">はじめての人</div>
        </button>
        <button class="diff-btn" data-diff="hard">
          むずかしい
          <div class="diff-desc">だんだんスピードアップする</div>
        </button>
        <button class="diff-btn" data-diff="extreme">
          めちゃムズ
          <div class="diff-desc">おジャマブロック登場</div>
        </button>
      </div>
      <button id="start-btn" class="start-btn">▶ ゲームスタート</button>
      <div class="control-group">
        <h3>iPad操作</h3>
        <p>スワイプ左右: 移動</p>
        <p>スワイプ下: ハードドロップ（慣性可変）</p>
        <p>タップ: 回転</p>
      </div>
      <div class="control-group">
        <h3>キーボード操作</h3>
        <p><span class="key">←</span> <span class="key">→</span> 左右移動</p>
        <p><span class="key">↓</span> ソフトドロップ</p>
        <p><span class="key">Space</span> ハードドロップ（慣性可変）</p>
        <p><span class="key">.</span> <span class="key">/</span> 回転</p>
        <p><span class="key">P</span> 一時停止</p>
        <p><span class="key">M</span> ミュート</p>
      </div>
    </div>
    <!-- Game Over Restart Button -->
    <button id="restart-btn" class="restart-btn">もう一度あそぶ</button>
    <button id="title-btn" class="title-btn">タイトルにもどる</button>
    <!-- iPad Touch Controls -->
    <div id="touch-controls">
      <div class="control-row">
        <button id="btn-rotate" class="touch-btn" aria-label="回転">↻</button>
      </div>
      <div class="control-row">
        <button id="btn-left" class="touch-btn" aria-label="左">←</button>
        <button id="btn-down" class="touch-btn" aria-label="下">↓</button>
        <button id="btn-right" class="touch-btn" aria-label="右">→</button>
      </div>
      <div class="control-row">
        <button id="btn-drop" class="touch-btn drop-btn" aria-label="ドロップ">⬇</button>
      </div>
    </div>
  </div>

  <script>
    // ===== AUDIO SYSTEM =====
    class AudioManager {
      constructor() {
        this.ctx = null;
        this.masterGain = null;
        this.bgmGain = null;
        this.muted = false;
      }

      init() {
        if (this.ctx) return;
        this.ctx = new (window.AudioContext || window.webkitAudioContext)();
        this.masterGain = this.ctx.createGain();
        this.masterGain.connect(this.ctx.destination);
        // Separate BGM gain for volume control
        this.bgmGain = this.ctx.createGain();
        this.bgmGain.gain.value = 0.15;
        this.bgmGain.connect(this.masterGain);
        this.loadMuteState();
      }

      getCtx() {
        if (!this.ctx) this.init();
        return this.ctx;
      }

      getMaster() {
        if (!this.masterGain) this.init();
        return this.masterGain;
      }

      getBgmNode() {
        if (!this.bgmGain) this.init();
        return this.bgmGain;
      }

      setMuted(muted) {
        this.muted = muted;
        if (this.masterGain) {
          this.masterGain.gain.value = muted ? 0 : 1;
        }
        // Also update BGM gain based on mute state
        if (this.bgmGain) {
          this.bgmGain.gain.value = muted ? 0 : (paused ? 0 : 0.15);
        }
        localStorage.setItem('candyDrops_muted', muted ? '1' : '0');
      }

      toggleMute() {
        this.setMuted(!this.muted);
      }

      loadMuteState() {
        const saved = localStorage.getItem('candyDrops_muted');
        if (saved === '1') this.setMuted(true);
      }
    }

    const audioManager = new AudioManager();

    // Audio utility functions
    function playTone(freq, type, duration, gain = 0.3, filterFreq = 4000) {
      const ctx = audioManager.getCtx();
      const now = ctx.currentTime;

      const osc = ctx.createOscillator();
      osc.type = type;
      osc.frequency.setValueAtTime(freq, now);

      const gainNode = ctx.createGain();
      gainNode.gain.setValueAtTime(gain, now);
      gainNode.gain.exponentialRampToValueAtTime(0.001, now + duration);

      const filter = ctx.createBiquadFilter();
      filter.type = 'lowpass';
      filter.frequency.setValueAtTime(filterFreq, now);

      osc.connect(filter).connect(gainNode).connect(audioManager.getMaster());
      osc.start(now);
      osc.stop(now + duration);
    }

    function playNotes(notes, type, noteDuration, gap, gain = 0.3, filterFreq = 4000) {
      const ctx = audioManager.getCtx();
      const now = ctx.currentTime;

      notes.forEach((freq, i) => {
        const start = now + i * gap;
        const osc = ctx.createOscillator();
        osc.type = type;
        osc.frequency.setValueAtTime(freq, start);

        const gainNode = ctx.createGain();
        gainNode.gain.setValueAtTime(gain, start);
        gainNode.gain.exponentialRampToValueAtTime(0.001, start + noteDuration);

        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(filterFreq, start);

        osc.connect(filter).connect(gainNode).connect(audioManager.getMaster());
        osc.start(start);
        osc.stop(start + noteDuration);
      });
    }

    function playNoise(duration, gain = 0.2, lpfFreq = 4000, hpfFreq = 0) {
      const ctx = audioManager.getCtx();
      const now = ctx.currentTime;
      const bufferSize = ctx.sampleRate * duration;
      const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
      const data = buffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;

      const source = ctx.createBufferSource();
      source.buffer = buffer;

      const gainNode = ctx.createGain();
      gainNode.gain.setValueAtTime(gain, now);
      gainNode.gain.exponentialRampToValueAtTime(0.001, now + duration);

      const lpf = ctx.createBiquadFilter();
      lpf.type = 'lowpass';
      lpf.frequency.setValueAtTime(lpfFreq, now);

      let chain = source.connect(lpf).connect(gainNode);

      if (hpfFreq > 0) {
        const hpf = ctx.createBiquadFilter();
        hpf.type = 'highpass';
        hpf.frequency.setValueAtTime(hpfFreq, now);
        source.disconnect();
        chain = source.connect(hpf).connect(lpf).connect(gainNode);
      }

      chain.connect(audioManager.getMaster());
      source.start(now);
      source.stop(now + duration);
    }

    // ===== GAME SFX =====
    // Note: C4=261.63, D4=293.66, E4=329.63, F4=349.23, G4=392.00, A4=440.00, B4=493.88, C5=523.25, E5=659.25, B5=987.77

    function moveSfx() {
      playTone(440, 'sine', 0.05, 0.15, 3000);
    }

    function rotateSfx() {
      playTone(523.25, 'square', 0.08, 0.2, 4000);
    }

    function landSfx() {
      playTone(196, 'triangle', 0.15, 0.25, 1500);
    }

    function chainSfx(level) {
      const chainLevel = Math.min(level, 5);
      const ctx = audioManager.getCtx();
      const now = ctx.currentTime;

      // Base frequency rises with chain level (C5=523 to G5=784)
      const baseFreq = 523.25 + chainLevel * 52;

      // Master gain for this chain
      const masterGain = ctx.createGain();
      masterGain.gain.setValueAtTime(0.25 + chainLevel * 0.03, now);
      masterGain.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
      masterGain.connect(audioManager.getMaster());

      // Rising arpeggio - feel of building up
      const numNotes = 3 + chainLevel;
      for (let i = 0; i < numNotes; i++) {
        const startTime = now + i * 0.05;
        const freq = baseFreq * (1 + i * 0.25); // Rising frequencies

        const osc = ctx.createOscillator();
        osc.type = i % 2 === 0 ? 'square' : 'triangle';
        osc.frequency.setValueAtTime(freq, startTime);

        const g = ctx.createGain();
        g.gain.setValueAtTime(0.15, startTime);
        g.gain.exponentialRampToValueAtTime(0.001, startTime + 0.2);

        const f = ctx.createBiquadFilter();
        f.type = 'lowpass';
        f.frequency.setValueAtTime(2500 + chainLevel * 300, startTime);

        osc.connect(f).connect(g).connect(masterGain);
        osc.start(startTime);
        osc.stop(startTime + 0.2);
      }

      // Final chord hit for chains >= 3
      if (chainLevel >= 3) {
        const chordFreqs = [baseFreq, baseFreq * 1.25, baseFreq * 1.5, baseFreq * 2];
        chordFreqs.forEach((freq, i) => {
          const osc = ctx.createOscillator();
          osc.type = 'sine';
          osc.frequency.setValueAtTime(freq, now + 0.15 + i * 0.02);
          const g = ctx.createGain();
          g.gain.setValueAtTime(0.12, now + 0.15 + i * 0.02);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.5);
          osc.connect(g).connect(masterGain);
          osc.start(now + 0.15 + i * 0.02);
          osc.stop(now + 0.5);
        });
      }

      // Sparkle burst for chains >= 4
      if (chainLevel >= 4) {
        for (let i = 0; i < 5; i++) {
          const osc = ctx.createOscillator();
          osc.type = 'square';
          osc.frequency.setValueAtTime(baseFreq * (3 + i * 0.5), now + 0.1 + i * 0.03);
          const g = ctx.createGain();
          g.gain.setValueAtTime(0.05, now + 0.1 + i * 0.03);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.25);
          const f = ctx.createBiquadFilter();
          f.type = 'lowpass';
          f.frequency.setValueAtTime(5000, now);
          osc.connect(f).connect(g).connect(masterGain);
          osc.start(now + 0.1 + i * 0.03);
          osc.stop(now + 0.25);
        }
      }
    }

    function gameOverSfx() {
      playNotes([392, 329.63, 261.63, 220, 174.61], 'square', 0.25, 0.12, 0.3, 2500);
    }

    function clickSfx() {
      playTone(523.25, 'sine', 0.06, 0.15, 5000);
    }

    // ===== BGM SYSTEM (pop & bright) =====
    const NOTES = {
      C3: 130.81, D3: 146.83, E3: 164.81, F3: 174.61, G3: 196.00, A3: 220.00,
      C4: 261.63, D4: 293.66, E4: 329.63, F4: 349.23, G4: 392.00, A4: 440.00, B4: 493.88,
      C5: 523.25, D5: 587.33, E5: 659.25, G5: 783.99, A5: 880.00
    };

    // Parse pattern string to note array
    function parsePattern(str, type = 'square', gain = 0.12, lpf = 3000) {
      return str.split(' ').map(n => {
        if (n === 'R' || n === '~') return { freq: 0 };
        return { freq: NOTES[n] || 0, type, gain, lpf };
      });
    }

    // Multi-phrase melodies for anti-repetition (4 variations = ~11 seconds per cycle)
    const melodies = [
      // Melody 1 - bright ascending
      parsePattern('E5 R D5 R C5 R D5 R E5 R D5 R C5 R D5 R', 'square', 0.08, 3500),
      // Melody 2 - playful
      parsePattern('G5 R A5 R G5 R E5 R D5 R C5 R D5 R E5 R', 'square', 0.08, 3500),
      // Melody 3 - happy bounce
      parsePattern('C5 R D5 R E5 R G5 R E5 R D5 R C5 R D5 R', 'square', 0.08, 3500),
      // Melody 4 - resolution
      parsePattern('E5 R G5 R A5 R G5 R E5 R D5 R C5 R E5 R', 'square', 0.08, 3500),
    ];

    // Bass pattern (8 steps, 2 bars)
    const bassPattern = parsePattern('C3 R G3 R A3 R F3 R C3 R G3 R A3 R', 'triangle', 0.1, 600);

    // Arpeggio pattern for brightness
    const arpeggioPattern = parsePattern('C5 R E5 R G5 R E5 R C5 R D5 R F5 R A5 R F5 R', 'square', 0.03, 4000);

    // Hi-hat on beats
    const hihatPattern = parsePattern('R 8000 R R R 8000 R R R 8000 R 8000 R R', 'sine', 0.03, 8000);

    // Sequencer state
    let bgmTimerId = null;
    let bgmStep = 0;
    let bgmPhrase = 0;
    const BPM = 130;
    const STEP_TIME = 60000 / BPM / 2; // 8th notes

    function startBGM() {
      stopBGM();
      const ctx = audioManager.getCtx();
      const dest = audioManager.getBgmNode();

      const playStep = () => {
        const now = ctx.currentTime;
        const phraseLen = melodies[0].length; // 16 steps
        const melodyStep = bgmStep % phraseLen;

        // Change phrase every 16 steps (about 3.7 seconds)
        if (melodyStep === 0 && bgmStep > 0) {
          bgmPhrase = (bgmPhrase + 1) % melodies.length;
        }

        // Melody
        const note = melodies[bgmPhrase][melodyStep];
        if (note.freq > 0) {
          const osc = ctx.createOscillator();
          osc.type = note.type;
          osc.frequency.value = note.freq;
          const g = ctx.createGain();
          g.gain.setValueAtTime(note.gain, now);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
          const f = ctx.createBiquadFilter();
          f.type = 'lowpass';
          f.frequency.value = note.lpf;
          osc.connect(f).connect(g).connect(dest);
          osc.start(now);
          osc.stop(now + 0.15);
        }

        // Bass
        const bassNote = bassPattern[bgmStep % bassPattern.length];
        if (bassNote.freq > 0) {
          const osc = ctx.createOscillator();
          osc.type = bassNote.type;
          osc.frequency.value = bassNote.freq;
          const g = ctx.createGain();
          g.gain.setValueAtTime(bassNote.gain, now);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.2);
          osc.connect(g).connect(dest);
          osc.start(now);
          osc.stop(now + 0.2);
        }

        // Arpeggio
        const arpNote = arpeggioPattern[bgmStep % arpeggioPattern.length];
        if (arpNote.freq > 0) {
          const osc = ctx.createOscillator();
          osc.type = arpNote.type;
          osc.frequency.value = arpNote.freq;
          const g = ctx.createGain();
          g.gain.setValueAtTime(arpNote.gain, now);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
          const f = ctx.createBiquadFilter();
          f.type = 'lowpass';
          f.frequency.value = arpNote.lpf;
          osc.connect(f).connect(g).connect(dest);
          osc.start(now);
          osc.stop(now + 0.08);
        }

        // Hi-hat
        const hihat = hihatPattern[bgmStep % hihatPattern.length];
        if (hihat.freq > 0) {
          const bufSize = ctx.sampleRate * 0.02;
          const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
          const data = buf.getChannelData(0);
          for (let i = 0; i < bufSize; i++) data[i] = Math.random() * 2 - 1;
          const noise = ctx.createBufferSource();
          noise.buffer = buf;
          const g = ctx.createGain();
          g.gain.setValueAtTime(0.035, now);
          g.gain.exponentialRampToValueAtTime(0.001, now + 0.02);
          const f = ctx.createBiquadFilter();
          f.type = 'highpass';
          f.frequency.value = 8000;
          noise.connect(f).connect(g).connect(dest);
          noise.start(now);
        }

        bgmStep++;
        bgmTimerId = setTimeout(playStep, STEP_TIME);
      };
      playStep();
    }

    function stopBGM() {
      if (bgmTimerId) {
        clearTimeout(bgmTimerId);
