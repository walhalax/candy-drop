    // ===== CANDY BACKGROUND ANIMATION =====
    (function initCandyBackground() {
      const bgCanvas = document.getElementById('candy-bg');
      const bgCtx = bgCanvas.getContext('2d');

      const PASTEL_COLORS = [
        '#ffb6c1', // light pink
        '#ffc0cb', // pink
        '#ffd1dc', // pastel pink
        '#ffe4e1', // misty rose
        '#e0bbE4', // lavender
        '#c3b1e1', // purple
        '#b4d4e7', // powder blue
        '#aec6cf', // past blue
        '#b2e2f2', // light azure
        '#98d8c8', // mint
        '#b5e7a0', // tea green
        '#f0e68c', // khaki
        '#fff0b3', // custard
        '#ffd700', // gold (light)
        '#ffdfba', // peach
        '#ffb347', // pastel orange
      ];

      const candies = [];
      const CANDY_COUNT = 45;

      function resize() {
        bgCanvas.width = window.innerWidth * 2;
        bgCanvas.height = window.innerHeight * 2;
      }
      resize();
      window.addEventListener('resize', resize);

      // Create candy shapes
      for (let i = 0; i < CANDY_COUNT; i++) {
        candies.push(createCandy());
      }

      function createCandy() {
        return {
          x: Math.random() * bgCanvas.width,
          y: Math.random() * bgCanvas.height,
          size: 20 + Math.random() * 60,
          color: PASTEL_COLORS[Math.floor(Math.random() * PASTEL_COLORS.length)],
          type: Math.floor(Math.random() * 3), // 0: circle, 1: wrapped candy, 2: star
          rotation: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.01,
          // Diagonal drift direction (all move same general direction)
          vx: 0.8 + Math.random() * 0.5,  // positive x (rightward)
          vy: 0.5 + Math.random() * 0.3,  // positive y (downward)
          alpha: 0.15 + Math.random() * 0.25,
          phase: Math.random() * Math.PI * 2,
        };
      }

      function drawWrappedCandy(x, y, size, color, rotation) {
        const cx = x;
        const cy = y;
        bgCtx.save();
        bgCtx.translate(cx, cy);
        bgCtx.rotate(rotation);
        bgCtx.globalAlpha = bgCtx.globalAlpha;

        // Wrapper body
        const bodyW = size * 0.5;
        const bodyH = size * 0.35;
        const bodyGrad = bgCtx.createRadialGradient(-bodyW * 0.2, -bodyH * 0.2, 0, 0, 0, bodyW * 0.7);
        bodyGrad.addColorStop(0, lightenColor(color, 40));
        bodyGrad.addColorStop(0.5, color);
        bodyGrad.addColorStop(1, darkenColor(color, 20));
        bgCtx.fillStyle = bodyGrad;

        // Rounded body
        bgCtx.beginPath();
        bgCtx.ellipse(0, 0, bodyW, bodyH, 0, 0, Math.PI * 2);
        bgCtx.fill();

        // Twisted ends
        bgCtx.fillStyle = darkenColor(color, 15);
        bgCtx.beginPath();
        bgCtx.moveTo(-bodyW, 0);
        bgCtx.lineTo(-bodyW - size * 0.25, -size * 0.12);
        bgCtx.lineTo(-bodyW - size * 0.25, size * 0.12);
        bgCtx.closePath();
        bgCtx.fill();

        bgCtx.beginPath();
        bgCtx.moveTo(bodyW, 0);
        bgCtx.lineTo(bodyW + size * 0.25, -size * 0.12);
        bgCtx.lineTo(bodyW + size * 0.25, size * 0.12);
        bgCtx.closePath();
        bgCtx.fill();

        bgCtx.restore();
      }

      function lightenColor(hex, percent) {
        const num = parseInt(hex.slice(1), 16);
        const r = Math.min(255, (num >> 16) + Math.floor(255 * percent / 100));
        const g = Math.min(255, ((num >> 8) & 0xff) + Math.floor(255 * percent / 100));
        const b = Math.min(255, (num & 0xff) + Math.floor(255 * percent / 100));
        return `rgb(${r},${g},${b})`;
      }

      function darkenColor(hex, percent) {
        const num = parseInt(hex.slice(1), 16);
        const r = Math.max(0, (num >> 16) - Math.floor(255 * percent / 100));
        const g = Math.max(0, ((num >> 8) & 0xff) - Math.floor(255 * percent / 100));
        const b = Math.max(0, (num & 0xff) - Math.floor(255 * percent / 100));
        return `rgb(${r},${g},${b})`;
      }

      function drawStar(x, y, size, color, rotation) {
        bgCtx.save();
        bgCtx.translate(x, y);
        bgCtx.rotate(rotation);
        bgCtx.globalAlpha = bgCtx.globalAlpha;
        bgCtx.fillStyle = color;
        bgCtx.beginPath();
        for (let i = 0; i < 5; i++) {
          const angle = (i * 4 * Math.PI) / 5 - Math.PI / 2;
          const r = i === 0 ? size : size;
          if (i === 0) bgCtx.moveTo(Math.cos(angle) * r, Math.sin(angle) * r);
          else bgCtx.lineTo(Math.cos(angle) * r, Math.sin(angle) * r);
          const innerAngle = angle + (2 * Math.PI) / 10;
          bgCtx.lineTo(Math.cos(innerAngle) * size * 0.4, Math.sin(innerAngle) * size * 0.4);
        }
        bgCtx.closePath();
        bgCtx.fill();
        bgCtx.restore();
      }

      function drawCircle(x, y, size, color, rotation) {
        bgCtx.save();
        bgCtx.translate(x, y);
        bgCtx.rotate(rotation);
        bgCtx.globalAlpha = bgCtx.globalAlpha;
        const grad = bgCtx.createRadialGradient(-size * 0.15, -size * 0.15, 0, 0, 0, size * 0.6);
        grad.addColorStop(0, lightenColor(color, 50));
        grad.addColorStop(0.5, color);
        grad.addColorStop(1, darkenColor(color, 15));
        bgCtx.fillStyle = grad;
        bgCtx.beginPath();
        bgCtx.arc(0, 0, size * 0.5, 0, Math.PI * 2);
        bgCtx.fill();
        bgCtx.restore();
      }

      function animate() {
        bgCtx.clearRect(0, 0, bgCanvas.width, bgCanvas.height);

        candies.forEach(c => {
          // Update position (diagonal drift)
          c.x += c.vx;
          c.y += c.vy;
          c.rotation += c.rotSpeed;

          // Wrap around edges diagonally
          if (c.x > bgCanvas.width + c.size) c.x = -c.size;
          if (c.y > bgCanvas.height + c.size) c.y = -c.size;

          // Pulsing alpha
          const pulseAlpha = c.alpha + Math.sin(Date.now() * 0.002 + c.phase) * 0.05;
          bgCtx.globalAlpha = Math.max(0.08, Math.min(0.45, pulseAlpha));

          // Draw candy shape
          if (c.type === 0) {
            drawCircle(c.x, c.y, c.size, c.color, c.rotation);
          } else if (c.type === 1) {
            drawWrappedCandy(c.x, c.y, c.size, c.color, c.rotation);
          } else {
            drawStar(c.x, c.y, c.size, c.color, c.rotation);
          }
        });

        requestAnimationFrame(animate);
      }

      animate();
    })();

    let board = [];
    let current = null;
    let nextPuyo = null;
    let score = 0;
    let chain = 0;
    let gameOver = false;
    let paused = false;
    let started = false;
