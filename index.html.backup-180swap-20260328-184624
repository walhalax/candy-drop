          started = true;
          overlay.classList.add('hidden');
          init();
          spawn();
          clickSfx();
          startBGM();
          return;
        }
        if (gameOver) return;
        action();
      }, { passive: false });
      btn.addEventListener('mousedown', (e) => {
        e.preventDefault();
        audioManager.init();
        if (!started) {
          started = true;
          overlay.classList.add('hidden');
          init();
          spawn();
          clickSfx();
          startBGM();
          return;
        }
        if (gameOver) return;
        action();
      });
    }

    setupTouchButton('btn-left', () => tryMove(-1));
    setupTouchButton('btn-right', () => tryMove(1));
    setupTouchButton('btn-down', () => drop());
    setupTouchButton('btn-drop', () => hardDrop());
    setupTouchButton('btn-rotate', () => tryRotate(1));

    // Long press for continuous move
    let moveInterval = null;
    function startContinuousMove(action) {
      action();
      moveInterval = setInterval(() => {
        if (!gameOver && started && !paused) action();
      }, 100);
    }
    function stopContinuousMove() {
      if (moveInterval) {
        clearInterval(moveInterval);
        moveInterval = null;
      }
    }

    ['btn-left', 'btn-right', 'btn-down'].forEach((id, i) => {
      const btn = document.getElementById(id);
      if (!btn) return;
      const actions = [() => tryMove(-1), () => tryMove(1), () => drop()];
      btn.addEventListener('touchstart', (e) => {
        e.preventDefault();
        audioManager.init();
        if (!started || gameOver || paused) return;
        actions[i]();
        startContinuousMove(actions[i]);
      }, { passive: false });
      btn.addEventListener('touchend', stopContinuousMove);
      btn.addEventListener('touchcancel', stopContinuousMove);
    });

    // Safety: document-level touchend/touchcancel to catch lost events on iOS
    document.addEventListener('touchend', stopContinuousMove);
    document.addEventListener('touchcancel', stopContinuousMove);

    // ===== Difficulty Selection =====
    const diffButtons = document.querySelectorAll('.diff-btn');
    diffButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        // Remove selected from all
        diffButtons.forEach(b => b.classList.remove('selected'));
        // Add selected to clicked
        btn.classList.add('selected');
        // Set difficulty
        difficulty = btn.dataset.diff;
        updateFallInterval();
      });
    });

    // ===== Overlay Click to Start =====
    overlay.addEventListener('click', (e) => {
      if (!started) {
        started = true;
        overlay.classList.add('hidden');
        init();
        spawn();
        clickSfx();
        startBGM();
      }
    });

    // ===== Start Button Click =====
    const startBtn = document.getElementById('start-btn');
    if (startBtn) {
      startBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (!started) {
          started = true;
          overlay.classList.add('hidden');
          init();
          spawn();
          clickSfx();
          startBGM();
        }
      });
    }

    // Restart button handler
    const restartBtn = document.getElementById('restart-btn');
    if (restartBtn) {
      restartBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        restartBtn.style.display = 'none';
        const titleBtn = document.getElementById('title-btn');
        if (titleBtn) titleBtn.style.display = 'none';
        init();
        spawn();
        clickSfx();
      });
    }

    // Title button handler
    const titleBtn = document.getElementById('title-btn');
    if (titleBtn) {
      titleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        restartBtn.style.display = 'none';
        titleBtn.style.display = 'none';
        started = false;
        gameOver = false;
        overlay.classList.remove('hidden');
        clickSfx();
      });
    }

    requestAnimationFrame(gameLoop);
  </script>
</body>
</html>
