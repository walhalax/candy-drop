    function getSatellitePos(puyo) {
      const [ox, oy] = ROT_OFFSETS[puyo.rot];
      return { x: puyo.x + ox, y: puyo.y + oy };
    }

    function canPlaceCell(x, y) {
      if (x < 0 || x >= COLS) return false;
      if (y >= ROWS) return false;
      if (y < 0) return true; // Above visible area is always passable (falling from above)
      return board[y][x] === null;
    }

    function canPlacePuyo(x, y, rot) {
      if (!canPlaceCell(x, y)) return false;
      const [ox, oy] = ROT_OFFSETS[rot];
      if (!canPlaceCell(x + ox, y + oy)) return false;
      return true;
    }

    // For rotation - only main block collision matters, satellite can pass through
    function canPlacePuyoForRotation(x, y, rot) {
      if (!canPlaceCell(x, y)) return false;
