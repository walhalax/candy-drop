    function placePuyo(puyo) {
      const x = Math.round(puyo.x);
      const y = Math.floor(puyo.y);
      const sp = getSatellitePos({ x, y, rot: puyo.rot });

      // Place on board first (before any checks)
      if (y >= 0 && y < ROWS && x >= 0 && x < COLS) board[y][x] = puyo.colors[0];
      if (sp.y >= 0 && sp.y < ROWS && sp.x >= 0 && sp.x < COLS) board[sp.y][sp.x] = puyo.colors[1];
      landSfx();

      // Check if placed blocks would be part of a match - if so, don't game over
      const gameOverCol = 3; // 右から3列目
      const gameOverY = 0;
      const wouldFormMatch = checkIfCellMatches(x, y) || (sp.x >= 0 && sp.x < COLS && sp.y >= 0 && sp.y < ROWS && checkIfCellMatches(sp.x, sp.y));

      // Only game over if at row 0, col 3 AND wouldn't form a match
      if ((y === gameOverY && x === gameOverCol) || (sp.y === gameOverY && sp.x === gameOverCol)) {
        if (!wouldFormMatch) {
          gameOver = true;
          gameOverSfx();
          stopBGM();
          const restartBtn = document.getElementById('restart-btn');
          if (restartBtn) restartBtn.style.display = 'block';
          const titleBtn = document.getElementById('title-btn');
          if (titleBtn) titleBtn.style.display = 'block';
        }
      }
    }

    // Check if a specific cell is part of a match (4+ connected same color)
    function checkIfCellMatches(x, y) {
      if (x < 0 || x >= COLS || y < 0 || y >= ROWS) return false;
      const color = board[y][x];
      if (!color || color === 'obstacle') return false;
      // Count connected cells of same color
      const visited = new Set();
      const count = countConnected(x, y, color, visited);
      return count >= 4;
    }

    function countConnected(x, y, color, visited) {
      const key = `${x},${y}`;
      if (x < 0 || x >= COLS || y < 0 || y >= ROWS) return 0;
      if (visited.has(key)) return 0;
      if (board[y][x] !== color) return 0;
      visited.add(key);
      let count = 1;
      count += countConnected(x + 1, y, color, visited);
      count += countConnected(x - 1, y, color, visited);
      count += countConnected(x, y + 1, color, visited);
      count += countConnected(x, y - 1, color, visited);
      return count;
    }

    function isOnGround(puyo) {
      // During rotation, main block still detects ground but satellite is allowed to pass through
      const x = Math.round(puyo.x);
      const y = Math.floor(puyo.y);
      // Check main block - always check even during rotation
      if (!canPlaceCell(x, y + 1)) return true;
      // Check satellite block - skip if satellite is outside game area or during rotation
      if (!isRotating && rotationCompleteTimer <= 0) {
        const sp = getSatellitePos(puyo);
        if (sp.x >= 0 && sp.x < COLS && sp.y >= 0 && sp.y < ROWS) {
          if (!canPlaceCell(sp.x, sp.y + 1)) return true;
        }
      }
      return false;
    }

    // Correct satellite position if it's outside the game area after rotation
    function correctSatellitePosition() {
      if (!current) return;
      const sp = getSatellitePos(current);
      let dx = 0, dy = 0;

      // Push satellite back into game area
      if (sp.x < 0) dx = -sp.x;           // Push right if satellite is too far left
      if (sp.x >= COLS) dx = COLS - 1 - sp.x; // Push left if satellite is too far right
      if (sp.y < 0) dy = -sp.y;           // Push down if satellite is too far up
      if (sp.y >= ROWS) dy = ROWS - 1 - sp.y; // Push up if satellite is too far down

      if (dx !== 0 || dy !== 0) {
        current.x += dx;
        current.y += dy;
        return;
      }

      // Check if satellite is overlapping with a block inside the game area
      if (sp.x >= 0 && sp.x < COLS && sp.y >= 0 && sp.y < ROWS) {
        if (board[sp.y][sp.x] !== null) {
          // Satellite is overlapping - try to push main block away from obstacle
          // Get the current rotation offset
          const [ox, oy] = ROT_OFFSETS[current.rot];

          // Special case: if satellite is below main (oy > 0) and there's space below main,
          // move main block down - this enables "position swap" rotation
          if (oy > 0 && canPlaceCell(current.x, current.y + 1)) {
            current.y += 1;
            return;
          }

          // Push direction is opposite to satellite offset (toward main block)
          let pushX = 0, pushY = 0;
          if (ox !== 0) pushX = -Math.sign(ox);
          if (oy !== 0) pushY = -Math.sign(oy);
          // Fallback for edge case
          if (pushX === 0 && pushY === 0) pushX = 1;

          // Try multiple push directions in order of preference
          const attempts = [
            { dx: pushX, dy: pushY },
            { dx: pushX, dy: 0 },
            { dx: 0, dy: pushY },
            { dx: -pushX, dy: pushY },
            { dx: pushX, dy: -pushY },
            { dx: 0, dy: 1 },
            { dx: 0, dy: -1 },
            { dx: 1, dy: 0 },
            { dx: -1, dy: 0 },
          ];

          for (const attempt of attempts) {
            const newX = current.x + attempt.dx;
            const newY = current.y + attempt.dy;
            const newSp = { x: newX + ox, y: newY + oy };

            // Check if new main position is valid
            if (!canPlaceCell(newX, newY)) continue;
            // Check if new satellite position is valid (empty or out of bounds)
            if (newSp.x >= 0 && newSp.x < COLS && newSp.y >= 0 && newSp.y < ROWS) {
              if (board[newSp.y][newSp.x] !== null) continue;
            }
            // Valid position found
            current.x = newX;
            current.y = newY;
            return;
          }
        }
      }
    }

    function tryMove(dx) {
      if (!current || gameOver || paused) return;
      const nx = current.x + dx;
      // During rotation or grace period, only check main block (satellite can be outside)
      if (isRotating || rotationCompleteTimer > 0) {
        if (canPlacePuyoForRotation(nx, current.y, current.rot)) {
          current.x = nx;
          moveSfx();
        }
      } else {
        if (canPlacePuyo(nx, current.y, current.rot)) {
          current.x = nx;
          moveSfx();
        }
      }
    }

    function tryRotate(dir) {
      if (!current || gameOver || paused) return;

      const mx = Math.round(current.x);
      const my = Math.floor(current.y);

      // Check if surrounded by blocks on both left AND right
      const leftBlocked = mx > 0 && my >= 0 && my < ROWS && board[my][mx - 1] !== null;
      const rightBlocked = mx + 1 < COLS && my >= 0 && my < ROWS && board[my][mx + 1] !== null;
      const surrounded = leftBlocked && rightBlocked;

      // If surrounded by blocks on both sides AND main has space below, perform 180-swap
      if (surrounded && canPlaceCell(mx, my + 1)) {
        const [ox, oy] = ROT_OFFSETS[current.rot];
        const mainColor = current.colors[0];
        const satColor = current.colors[1];

        // Swap: main moves to satellite's position, satellite moves to main's old position
        current.x = mx + ox;
        current.y = my + oy;
        current.colors[0] = satColor;
        current.colors[1] = mainColor;

        isRotating = true;
        rotationTimer = ROTATION_DURATION;
        rotateSfx();
        return;
      }

      // Normal 90-degree rotation (only if not surrounded on both sides)
      const newRot = (current.rot + dir + 4) % 4;
      const newX = current.x;
      const newY = current.y;

      const push = getSatelliteCollisionPush(newX, newY, newRot);
      if (push) {
        const pushedX = newX + push.dx;
        const pushedY = newY + push.dy;
        if (canPlacePuyoForRotation(pushedX, pushedY, newRot)) {
          current.x = pushedX;
          current.y = pushedY;
          current.rot = newRot;
          isRotating = true;
          rotationTimer = ROTATION_DURATION;
          rotateSfx();
          return;
        }
      }

      if (canPlacePuyoForRotation(newX, newY, newRot)) {
        current.rot = newRot;
        isRotating = true;
        rotationTimer = ROTATION_DURATION;
        rotateSfx();
        return;
      }

      const kicks = dir === 1 ? [1, -1, 2] : [-1, 1, -2];
      for (const kick of kicks) {
        const kx = newX + kick;
        const kPush = getSatelliteCollisionPush(kx, newY, newRot);
        if (kPush) {
          const pushedKX = kx + kPush.dx;
          const pushedKY = newY + kPush.dy;
          if (canPlacePuyoForRotation(pushedKX, pushedKY, newRot)) {
            current.x = pushedKX;
            current.y = pushedKY;
            current.rot = newRot;
            isRotating = true;
            rotationTimer = ROTATION_DURATION;
            rotateSfx();
            return;
          }
        }
        if (canPlacePuyoForRotation(kx, newY, newRot)) {
          current.x = kx;
          current.rot = newRot;
          isRotating = true;
          rotationTimer = ROTATION_DURATION;
          rotateSfx();
          return;
        }
      }
    }

    function drop() {
      if (!current || gameOver || paused) return;
      softDrop = true;
    }

    function hardDrop(distance = -1) {
      if (!current || gameOver || paused || fastDrop) return;
      // Temporarily move current down to find landing position (respecting satellite collision via isOnGround)
      const origY = current.y;
      let dropped = 0;
      while (dropped !== distance && !isOnGround(current)) {
        current.y++;
        dropped++;
      }
      fastDropTargetY = current.y;
      current.y = origY; // Restore original position for animation
      fastDrop = true;
      fastDropFrameSkip = 0; // Reset frame skip
    }

    function startObstaclePhase() {
      obstaclePhase = true;
      obstacleTimer = OBSTACLE_PHASE_DURATION;
      // Create obstacle block at random x, above visible area
      obstacleBlock = {
        x: Math.floor(Math.random() * COLS),
        y: -1,
        alpha: 0.25
      };
    }

    function updateObstaclePhase(delta) {
      if (!obstaclePhase) return;

      // Guard: if obstacleBlock is null but obstaclePhase is still true, force end
      if (!obstacleBlock) {
        obstaclePhase = false;
        obstacleDrops = 0;
        return;
      }

      // Move obstacle down faster than normal
      obstacleBlock.y += delta / 200; // ~200ms per cell
      obstacleTimer -= delta;

      const nextY = Math.floor(obstacleBlock.y) + 1;

      // Check if obstacle has landed (at bottom row OR cell below is occupied)
      if (nextY >= ROWS || board[nextY]?.[obstacleBlock.x] !== null) {
        // Land the obstacle at current or last valid position
        const landY = Math.min(Math.floor(obstacleBlock.y), ROWS - 1);
        if (landY >= 0) {
          board[landY][obstacleBlock.x] = 'obstacle';
        }
        obstacleBlock = null;
        // End obstacle phase after landing
        obstaclePhase = false;
        obstacleDrops = 0;
        return;
      }

      // End obstacle phase after duration even if not landed yet
      if (obstacleTimer <= 0) {
        // Force land it
        const landY = Math.min(Math.floor(obstacleBlock.y), ROWS - 1);
        if (landY >= 0) {
          board[landY][obstacleBlock.x] = 'obstacle';
        }
        obstacleBlock = null;
        obstaclePhase = false;
        obstacleDrops = 0;
      }
    }

    function applyGravity() {
      let moved = false;
      for (let x = 0; x < COLS; x++) {
        for (let y = ROWS - 2; y >= 0; y--) {
          if (board[y][x] !== null && board[y + 1][x] === null) {
            board[y + 1][x] = board[y][x];
            board[y][x] = null;
            moved = true;
          }
        }
      }
      return moved;
    }

    function floodFill(x, y, color, visited) {
      if (x < 0 || x >= COLS || y < 0 || y >= ROWS) return [];
      const key = `${x},${y}`;
      if (visited.has(key)) return [];
      if (board[y][x] !== color) return [];
      visited.add(key);
      let cells = [[x, y]];
      cells = cells.concat(floodFill(x + 1, y, color, visited));
      cells = cells.concat(floodFill(x - 1, y, color, visited));
      cells = cells.concat(floodFill(x, y + 1, color, visited));
      cells = cells.concat(floodFill(x, y - 1, color, visited));
      return cells;
    }

    function checkMatches() {
      const visited = new Set();
      let totalCleared = 0;
      let chains = 0;
      let clearedCells = [];

      for (let y = 0; y < ROWS; y++) {
        for (let x = 0; x < COLS; x++) {
          if (board[y][x] !== null && !visited.has(`${x},${y}`)) {
            const cells = floodFill(x, y, board[y][x], visited);
            if (cells.length >= 4) {
              chains++;
              const color = board[y][x];
              cells.forEach(([cx, cy]) => {
                clearedCells.push([cx, cy, color]);
                board[cy][cx] = null;
              });
              totalCleared += cells.length;
              score += cells.length * 10 * chains;
            }
          }
        }
      }

      // Remove adjacent obstacle blocks (obstacles are cleared when adjacent blocks are cleared)
      if (totalCleared > 0) {
        const toRemove = new Set();
        clearedCells.forEach(([cx, cy]) => {
          // Check 4 adjacent cells
          const adj = [[cx-1, cy], [cx+1, cy], [cx, cy-1], [cx, cy+1]];
          adj.forEach(([ax, ay]) => {
            if (ax >= 0 && ax < COLS && ay >= 0 && ay < ROWS) {
              if (board[ay][ax] === 'obstacle') {
                toRemove.add(`${ax},${ay}`);
              }
            }
          });
        });
        toRemove.forEach(key => {
          const [ox, oy] = key.split(',').map(Number);
          clearedCells.push([ox, oy, '#aaaaaa']);
          board[oy][ox] = null;
        });
      }

      if (totalCleared > 0) {
        chain = chains;
        updateUI();
        return clearedCells;
      }
      return null;
    }

    function update(delta) {
      if (!started || gameOver || paused) return;

      // Update rotation timer and complete delay
      if (isRotating) {
        rotationTimer -= delta;
        if (rotationTimer <= 0) {
          rotationTimer = 0;
          isRotating = false;
          // Push satellite into game area if it's outside
          correctSatellitePosition();
          rotationCompleteTimer = ROTATION_COMPLETE_DELAY;
        }
      }
      if (rotationCompleteTimer > 0) {
        rotationCompleteTimer -= delta;
        if (rotationCompleteTimer < 0) rotationCompleteTimer = 0;
      }

      // Burst animation - ALWAYS updates, even during freeze
      if (burstingCells.length > 0) {
        burstTimer += delta;
        if (burstTimer >= BURST_DURATION) {
          // Animation finished
          burstingCells = [];
          burstTimer = 0;
          // Apply gravity then check for chain
          applyGravity();
        }
        // Burst animation continues even during freeze
      }

      // Freeze effect - only blocks game logic, not animations
      if (freezeTimer > 0) {
        freezeTimer -= delta;
        if (freezeTimer <= 0) {
          freezeTimer = 0;
        }
        return; // Skip game logic update during freeze (but burst animation already updated above)
      }

      // Obstacle phase update (extreme mode)
      if (obstaclePhase) {
        updateObstaclePhase(delta);
        // During obstacle phase, don't spawn new blocks or allow normal falling
        return;
      }

      // Stage 2: Gravity settling (blocks falling after clear)
      let gravityMoved = applyGravity();
      if (gravityMoved) {
        // Wait for gravity to finish
        return;
      }

      // Stage 3: Check for chain reactions after gravity
      const chainCleared = checkMatches();
      if (chainCleared) {
        burstingCells = chainCleared;
        burstTimer = 0;

        // Increment cascade chain counter
        cascadeChain++;
        chain = cascadeChain; // Sync display counter
        updateUI(); // Update chain display immediately

        // Play chain sound
        chainSfx(cascadeChain);

        // Trigger freeze - first chain sets initial freeze, subsequent chains extend it
        if (cascadeChain === 1) {
          freezeTimer = FREEZE_DURATION;
        } else {
          // Extend freeze for chain continuation (cap at 2000ms to prevent infinite freeze)
          freezeTimer = Math.min(freezeTimer + BURST_DURATION, 2000);
        }
        chainLevel = Math.min(cascadeChain, 5);

        // Flash effect - 2連鎖から段階的に増幅
        flashIntensity = 0.4 + chainLevel * 0.15;
        flashColor = rainbowColors[chainLevel - 1] || '#ffffff';
        flashRadius = 0;

        // Instant flash - 段階的増幅
        instantFlash = 0.3 + chainLevel * 0.12;

        // Screen shake - 段階的増幅
        shakeIntensity = 2 + chainLevel * 2;

        // Chain popup text
        if (cascadeChain >= 2) {
          const chainTexts = ['', '', '2連続!!', '3連続!!!', '4連続!!!!', '5連続!!!!!'];
          const chainColors = ['#ffffff', '#ffffff', '#ff3366', '#ff69b4', '#ff1493', '#ff1493'];
          popupText = chainTexts[chainLevel] || '';
          popupColor = chainColors[chainLevel] || '#ffffff';
          popupAlpha = 1.0;
          popupScale = 0.9 + chainLevel * 0.25;
        }

        // Shockwaves from burst cells - 段階的増幅
        burstingCells.forEach(([cx, cy]) => {
          shockwaves.push({
            x: cx * CELL + CELL / 2 + GRID_OFFSET_X,
            y: cy * CELL + CELL / 2 + GRID_OFFSET_Y,
            radius: 0,
            maxRadius: CELL * (2 + chainLevel * 1.0),
            alpha: 0.7 + chainLevel * 0.06
          });
        });

        // Center glow - 段階的増幅
        centerGlow = 0.2 + chainLevel * 0.2;

        // Freeze pulse - 段階的増幅
        freezePulse = 0.2 + chainLevel * 0.15;

        return;
      }

      // Check if we should start pending obstacle phase (after all chain/gravity settling complete)
      if (pendingObstacle && !obstaclePhase) {
        startObstaclePhase();
        pendingObstacle = false;
        return; // Don't spawn new block during obstacle phase
      }

      // Stage 4: Spawn new puyo if none exists
      if (current === null) {
        spawn();
      }

      // Fast drop animation (high-speed fall with lower FPS)
      if (fastDrop && current) {
        fastDropFrameSkip++;
        if (fastDropFrameSkip > FAST_DROP_FRAME_SKIP) {
          fastDropFrameSkip = 0;
        }
        if (fastDropFrameSkip === 0) {
          const fastFallSpeed = fallInterval / 150; // 10x faster than soft drop
          current.y += delta / fastFallSpeed;
        }
        if (current.y >= fastDropTargetY) {
          current.y = fastDropTargetY;
          placePuyo(current);
          current = null;
          fastDrop = false;
          totalDrops++;
          obstacleDrops++;
          updateFallInterval();
          // Check if we should trigger obstacle phase in extreme mode (after resolution completes)
          if (difficulty === 'extreme' && obstacleDrops >= DROP_INTERVAL_FOR_OBSTACLE && !obstaclePhase && !pendingObstacle) {
            pendingObstacle = true; // Will start after current flow completes
          }
        }
      }

      // Stage 5: Normal falling
      if (current && !fastDrop) {
        fallTimer += delta;
        const interval = softDrop ? fallInterval / 15 : fallInterval;

        if (fallTimer >= interval) {
          fallTimer = 0;

          if (isOnGround(current)) {
            placePuyo(current);
            current = null;
            // Check if we should trigger obstacle phase in extreme mode (after resolution completes)
            if (difficulty === 'extreme' && obstacleDrops >= DROP_INTERVAL_FOR_OBSTACLE && !obstaclePhase && !pendingObstacle) {
              pendingObstacle = true; // Will start after current flow completes
            }
          } else {
            current.y++;
            softDrop = false;
          }
        }
      }
    }

    // Cached wrapped candy rotations for consistent per-cell rotation
    const candyRotations = new Map();
    function getCandyRotation(x, y) {
      const key = `${x},${y}`;
      if (!candyRotations.has(key)) {
        candyRotations.set(key, (Math.random() - 0.5) * 0.4);
      }
      return candyRotations.get(key);
    }

    function drawWrappedCandy(ctx, x, y, color, size = CELL, alpha = 1, rotation = 0, isObstacle = false) {
      ctx.save();
      ctx.globalAlpha = alpha;

      const padding = 3;
      const candyWidth = size - padding * 2;
      const candyHeight = size - padding * 2;
      const cx = x + size / 2;
      const cy = y + size / 2;

      // Apply rotation around center
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.translate(-cx, -cy);

      // Shadow - lighter for obstacle
      ctx.shadowColor = isObstacle ? 'rgba(200,200,200,0.3)' : 'rgba(0,0,0,0.2)';
      ctx.shadowBlur = isObstacle ? 8 : 5;
      ctx.shadowOffsetY = isObstacle ? 3 : 2;

      // ===== CANDY BODY (plump rounded rectangle) =====
      const bodyWidth = candyWidth * 0.55;
      const bodyHeight = candyHeight * 0.7;
      const bodyX = cx - bodyWidth / 2;
      const bodyY = cy - bodyHeight / 2;

      // Body with inner glow gradient (metallic sheen) - darker for obstacle
      const bodyGrad = ctx.createRadialGradient(
        cx - bodyWidth * 0.2, cy - bodyHeight * 0.2, 0,
        cx, cy, bodyWidth * 0.8
      );
      if (isObstacle) {
        bodyGrad.addColorStop(0, '#ffffff');
        bodyGrad.addColorStop(0.4, '#dddddd');
        bodyGrad.addColorStop(0.7, '#bbbbbb');
        bodyGrad.addColorStop(1, '#999999');
      } else {
        bodyGrad.addColorStop(0, lightenColor(color, 60));
        bodyGrad.addColorStop(0.4, color);
        bodyGrad.addColorStop(0.7, shadeColor(color, 15));
        bodyGrad.addColorStop(1, shadeColor(color, 35));
      }
      ctx.fillStyle = bodyGrad;

      // Rounded body shape
      const radius = bodyHeight * 0.35;
      ctx.beginPath();
      ctx.moveTo(bodyX + radius, bodyY);
      ctx.lineTo(bodyX + bodyWidth - radius, bodyY);
      ctx.quadraticCurveTo(bodyX + bodyWidth, bodyY, bodyX + bodyWidth, bodyY + radius);
      ctx.lineTo(bodyX + bodyWidth, bodyY + bodyHeight - radius);
      ctx.quadraticCurveTo(bodyX + bodyWidth, bodyY + bodyHeight, bodyX + bodyWidth - radius, bodyY + bodyHeight);
      ctx.lineTo(bodyX + radius, bodyY + bodyHeight);
      ctx.quadraticCurveTo(bodyX, bodyY + bodyHeight, bodyX, bodyY + bodyHeight - radius);
      ctx.lineTo(bodyX, bodyY + radius);
      ctx.quadraticCurveTo(bodyX, bodyY, bodyX + radius, bodyY);
      ctx.closePath();
      ctx.fill();

      // Draw light border for obstacle
      if (isObstacle) {
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 3;
        ctx.stroke();
      }

      // ===== TWISTED WRAPPER LEFT =====
      ctx.shadowBlur = 0;
      const twistLength = candyWidth * 0.3;
      const twistWidth = candyHeight * 0.28;
      const leftTwistX = bodyX - twistLength;

      // Left wrapper gradient (metallic paper) - lighter for obstacle
      const leftGrad = ctx.createLinearGradient(leftTwistX, cy - twistWidth, leftTwistX + twistLength, cy);
      if (isObstacle) {
        leftGrad.addColorStop(0, '#cccccc');
        leftGrad.addColorStop(0.3, '#cccccc');
        leftGrad.addColorStop(0.6, '#bbbbbb');
        leftGrad.addColorStop(1, '#aaaaaa');
      } else {
        leftGrad.addColorStop(0, shadeColor(color, 45));
        leftGrad.addColorStop(0.3, shadeColor(color, 20));
        leftGrad.addColorStop(0.6, lightenColor(color, 25));
        leftGrad.addColorStop(1, color);
      }
      ctx.fillStyle = leftGrad;

      // Left twisted end (gathered paper effect)
      ctx.beginPath();
      ctx.moveTo(bodyX, cy - bodyHeight * 0.28);
      ctx.lineTo(leftTwistX + twistLength * 0.15, cy - twistWidth * 0.9);
      ctx.lineTo(leftTwistX, cy - twistWidth * 0.5);
      ctx.lineTo(leftTwistX, cy + twistWidth * 0.5);
      ctx.lineTo(leftTwistX, cy + twistWidth * 0.5);
      ctx.lineTo(leftTwistX, cy - twistWidth * 0.5);
      ctx.lineTo(leftTwistX, cy - twistWidth * 0.5);
      ctx.lineTo(leftTwistX, cy - twistWidth * 0.5);
      ctx.moveTo(leftTwistX, cy - twistWidth * 0.5);
      ctx.lineTo(leftTwistX + twistLength * 0.15, cy + twistWidth * 0.9);
      ctx.lineTo(bodyX, cy + bodyHeight * 0.28);
      ctx.closePath();
      ctx.fill();

      // Left twist radial lines (paper gathering detail) - darker for obstacle
      ctx.strokeStyle = isObstacle ? '#888888' : shadeColor(color, 30);
      ctx.lineWidth = isObstacle ? 1.5 : 0.8;
      for (let i = 0; i < 5; i++) {
        const angle = (i - 2) * 0.15;
        const innerR = bodyHeight * 0.28;
        const outerR = twistWidth * 0.85;
        ctx.beginPath();
        ctx.moveTo(bodyX - 2, cy + Math.sin(angle) * innerR);
        ctx.lineTo(leftTwistX + twistLength * 0.1, cy + Math.sin(angle) * outerR);
        ctx.stroke();
      }

      // ===== TWISTED WRAPPER RIGHT =====
      const rightTwistX = bodyX + bodyWidth;

      // Right wrapper gradient - lighter for obstacle
      const rightGrad = ctx.createLinearGradient(rightTwistX, cy, rightTwistX + twistLength, cy);
      if (isObstacle) {
        rightGrad.addColorStop(0, '#aaaaaa');
        rightGrad.addColorStop(0.4, '#bbbbbb');
        rightGrad.addColorStop(0.7, '#cccccc');
        rightGrad.addColorStop(1, '#cccccc');
      } else {
        rightGrad.addColorStop(0, color);
        rightGrad.addColorStop(0.4, lightenColor(color, 25));
        rightGrad.addColorStop(0.7, shadeColor(color, 20));
        rightGrad.addColorStop(1, shadeColor(color, 45));
      }
      ctx.fillStyle = rightGrad;

      // Right twisted end
      ctx.beginPath();
      ctx.moveTo(bodyX + bodyWidth, cy - bodyHeight * 0.28);
      ctx.lineTo(rightTwistX + twistLength * 0.85, cy - twistWidth * 0.9);
      ctx.lineTo(rightTwistX + twistLength, cy - twistWidth * 0.5);
      ctx.lineTo(rightTwistX + twistLength, cy + twistWidth * 0.5);
      ctx.lineTo(rightTwistX + twistLength * 0.85, cy + twistWidth * 0.9);
      ctx.lineTo(bodyX + bodyWidth, cy + bodyHeight * 0.28);
      ctx.closePath();
      ctx.fill();

      // Right twist radial lines - darker for obstacle
      ctx.strokeStyle = isObstacle ? '#888888' : shadeColor(color, 30);
      ctx.lineWidth = isObstacle ? 1.5 : 0.8;
      for (let i = 0; i < 5; i++) {
        const angle = (i - 2) * 0.15;
        const innerR = bodyHeight * 0.28;
        const outerR = twistWidth * 0.85;
        ctx.beginPath();
        ctx.moveTo(bodyX + bodyWidth + 2, cy + Math.sin(angle) * innerR);
        ctx.lineTo(rightTwistX + twistLength * 0.9, cy + Math.sin(angle) * outerR);
        ctx.stroke();
      }

      // ===== BODY HIGHLIGHT (inner luminescence) - reduced for obstacle =====
      ctx.shadowBlur = 0;
      const hlGrad = ctx.createRadialGradient(
        cx - bodyWidth * 0.15, cy - bodyHeight * 0.2, 0,
        cx, cy, bodyWidth * 0.5
      );
      if (isObstacle) {
        hlGrad.addColorStop(0, 'rgba(255,255,255,0.15)');
        hlGrad.addColorStop(0.5, 'rgba(255,255,255,0.05)');
        hlGrad.addColorStop(1, 'rgba(255,255,255,0)');
      } else {
        hlGrad.addColorStop(0, 'rgba(255,255,255,0.55)');
        hlGrad.addColorStop(0.5, 'rgba(255,255,255,0.15)');
        hlGrad.addColorStop(1, 'rgba(255,255,255,0)');
      }
      ctx.fillStyle = hlGrad;
      ctx.beginPath();
      ctx.ellipse(cx - bodyWidth * 0.08, cy - bodyHeight * 0.15, bodyWidth * 0.28, bodyHeight * 0.2, -0.3, 0, Math.PI * 2);
      ctx.fill();

      // Specular dot - brighter for obstacle
      ctx.fillStyle = isObstacle ? 'rgba(255,255,255,0.7)' : 'rgba(255,255,255,0.9)';
      ctx.beginPath();
      ctx.arc(cx + bodyWidth * 0.18, cy - bodyHeight * 0.18, 2.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.restore();
    }

    // Wrapper for backward compatibility
    function drawPuyo(ctx, x, y, color, size = CELL, alpha = 1) {
      const rotation = getCandyRotation(
        Math.round((x - GRID_OFFSET_X) / CELL),
        Math.round((y - GRID_OFFSET_Y) / CELL)
      );
      drawWrappedCandy(ctx, x, y, color, size, alpha, rotation);
    }

    function roundRect(ctx, x, y, w, h, r) {
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + w - r, y);
      ctx.quadraticCurveTo(x + w, y, x + w, y + r);
      ctx.lineTo(x + w, y + h - r);
      ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
      ctx.lineTo(x + r, y + h);
      ctx.quadraticCurveTo(x, y + h, x, y + h - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
    }

    function lightenColor(color, percent) {
      const num = parseInt(color.slice(1), 16);
      const r = Math.min(255, Math.max(0, (num >> 16) + percent));
      const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + percent));
      const b = Math.min(255, Math.max(0, (num & 0x0000FF) + percent));
      return `#${(1 << 24 | r << 16 | g << 8 | b).toString(16).slice(1)}`;
    }

    function drawBurstParticle(ctx, x, y, color, progress) {
      // Simple lightweight burst effect - no loops, no save/restore
      const cx = x + CELL / 2;
      const cy = y + CELL / 2;
      const alpha = 1 - progress;
      const radius = CELL * (0.5 + progress * 2);

      // Simple radial gradient glow
      const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, radius);
      grad.addColorStop(0, `rgba(255,255,255,${alpha * 0.8})`);
      grad.addColorStop(0.3, hexToRgba(color, alpha * 0.5));
      grad.addColorStop(1, 'transparent');
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.fill();
    }

    function hexToRgba(hex, alpha) {
      const num = parseInt(hex.slice(1), 16);
      const r = (num >> 16) & 255;
      const g = (num >> 8) & 255;
      const b = num & 255;
      return `rgba(${r},${g},${b},${alpha})`;
    }

    function drawStar(ctx, cx, cy, outerR, innerR) {
      const points = 4;
      ctx.beginPath();
      for (let i = 0; i < points * 2; i++) {
        const r = i % 2 === 0 ? outerR : innerR;
        const angle = (i * Math.PI) / points - Math.PI / 2;
        const x = cx + Math.cos(angle) * r;
        const y = cy + Math.sin(angle) * r;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
    }

    function drawHeart(ctx, cx, cy, size) {
      const x = cx - size / 2;
      const y = cy - size / 2;
      const width = size;
      const height = size * 0.9;

      ctx.beginPath();
      ctx.moveTo(width / 2, height * 0.3);
      ctx.bezierCurveTo(width / 2, height * 0.1, width * 0.2, 0, 0, height * 0.3);
      ctx.bezierCurveTo(-width * 0.3, height * 0.6, width / 2, height, width / 2, height);
      ctx.bezierCurveTo(width / 2, height, width * 1.3, height * 0.6, width, height * 0.3);
      ctx.bezierCurveTo(width * 0.8, 0, width / 2, height * 0.1, width / 2, height * 0.3);
      ctx.closePath();
    }

    function hexToRgb(hex) {
      const num = parseInt(hex.slice(1), 16);
      return {
        r: (num >> 16) & 255,
        g: (num >> 8) & 255,
        b: num & 255
      };
    }

    function shadeColor(color, percent) {
      const num = parseInt(color.slice(1), 16);
      const r = Math.min(255, Math.max(0, (num >> 16) + percent));
      const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + percent));
      const b = Math.min(255, Math.max(0, (num & 0x0000FF) + percent));
      return `#${(1 << 24 | r << 16 | g << 8 | b).toString(16).slice(1)}`;
    }

    function draw() {
      // INSTANT FLASH - rainbow wave spreading
      if (instantFlash > 0 && burstingCells.length > 0) {
        const ifc = hexToRgb(instantFlashColor);
        burstingCells.forEach(([x, y, color]) => {
          const cx = x * CELL + CELL / 2 + GRID_OFFSET_X;
          const cy = y * CELL + CELL / 2 + GRID_OFFSET_Y;
          const maxRadius = Math.max(canvas.width, canvas.height) * 2;

          // Rainbow expanding circle
          const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxRadius * instantFlash);
          grad.addColorStop(0, `rgba(${ifc.r},${ifc.g},${ifc.b},${instantFlash * 0.3})`);
          grad.addColorStop(0.3, `rgba(${ifc.r},${ifc.g},${ifc.b},${instantFlash * 0.15})`);
          grad.addColorStop(0.6, `rgba(${ifc.r},${ifc.g},${ifc.b},${instantFlash * 0.05})`);
          grad.addColorStop(1, 'transparent');
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, canvas.width, canvas.height);
        });

        instantFlash *= 0.75;
        if (instantFlash < 0.03) instantFlash = 0;
      }

      // Subtle transparent overlay so candy background shows through
      const time = lastTime;
      const bgGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
      bgGrad.addColorStop(0, 'rgba(255, 240, 245, 0.25)');
      bgGrad.addColorStop(0.5, 'rgba(255, 230, 240, 0.2)');
      bgGrad.addColorStop(1, 'rgba(255, 220, 235, 0.25)');
      ctx.fillStyle = bgGrad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // MASSIVE Flash effect - rainbow wave spreading with sparkles
      if (flashIntensity > 0 && burstingCells.length > 0) {
        const fc = hexToRgb(flashColor);
        burstingCells.forEach(([x, y, color]) => {
          const cx = x * CELL + CELL / 2 + GRID_OFFSET_X;
          const cy = y * CELL + CELL / 2 + GRID_OFFSET_Y;

          // Rainbow expanding wave
          const maxRadius = Math.max(canvas.width, canvas.height) * 2;
          const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxRadius * flashIntensity);
          grad.addColorStop(0, `rgba(${fc.r},${fc.g},${fc.b},${flashIntensity * 0.3})`);
          grad.addColorStop(0.3, `rgba(${fc.r},${fc.g},${fc.b},${flashIntensity * 0.15})`);
          grad.addColorStop(0.6, `rgba(${fc.r},${fc.g},${fc.b},${flashIntensity * 0.05})`);
          grad.addColorStop(1, 'transparent');
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, canvas.width, canvas.height);
        });

        // Decay flash
        flashIntensity *= 0.82;
        if (flashIntensity < 0.02) flashIntensity = 0;
      }

      // Apply screen shake to ALL elements (effects + game)
      ctx.save();
      ctx.translate(shakeOffsetX, shakeOffsetY);

      // Draw shockwaves
      shockwaves.forEach(sw => {
        ctx.save();
        ctx.globalAlpha = sw.alpha;
        ctx.strokeStyle = rainbowColors[chainLevel - 1] || '#ffffff';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.arc(sw.x, sw.y, sw.radius, 0, Math.PI * 2);
        ctx.stroke();
        ctx.restore();
        // Update shockwave
        sw.radius += 8 + sw.maxRadius * 0.05;
        sw.alpha *= 0.92;
      });
      // Remove finished shockwaves
      shockwaves = shockwaves.filter(sw => sw.alpha > 0.02 && sw.radius < sw.maxRadius);

      // Draw center glow
      if (centerGlow > 0) {
        const cx = GRID_OFFSET_X + (COLS * CELL) / 2;
        const cy = GRID_OFFSET_Y + (ROWS * CELL) / 2;
        const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, CELL * 6);
        const glowColor = rainbowColors[chainLevel - 1] || '#ffffff';
        grad.addColorStop(0, glowColor);
        grad.addColorStop(0.5, `${glowColor}88`);
        grad.addColorStop(1, 'transparent');
        ctx.save();
        ctx.globalAlpha = centerGlow;
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.restore();
        centerGlow *= 0.94;
        if (centerGlow < 0.02) centerGlow = 0;
      }

      // Draw freeze pulse (screen tint during freeze)
      if (freezePulse > 0 && freezeTimer > 0) {
        ctx.save();
        ctx.globalAlpha = freezePulse * 0.3;
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.restore();
        freezePulse *= 0.95;
      }

      // Draw grid lines (subtle pink)
      ctx.strokeStyle = 'rgba(255, 182, 193, 0.4)';
      ctx.lineWidth = 1;
      for (let y = 0; y <= ROWS; y++) {
        ctx.beginPath();
        ctx.moveTo(GRID_OFFSET_X, y * CELL + GRID_OFFSET_Y);
        ctx.lineTo(GRID_OFFSET_X + COLS * CELL, y * CELL + GRID_OFFSET_Y);
        ctx.stroke();
      }
      for (let x = 0; x <= COLS; x++) {
        ctx.beginPath();
        ctx.moveTo(x * CELL + GRID_OFFSET_X, GRID_OFFSET_Y);
        ctx.lineTo(x * CELL + GRID_OFFSET_X, GRID_OFFSET_Y + ROWS * CELL);
        ctx.stroke();
      }

      // Draw outer border (aligned with grid lines)
      ctx.strokeStyle = 'rgba(255, 105, 180, 0.8)';
      ctx.lineWidth = 2;
      ctx.strokeRect(GRID_OFFSET_X, GRID_OFFSET_Y, COLS * CELL, ROWS * CELL);

      // Draw burst particles
      if (burstingCells.length > 0) {
        const progress = Math.min(burstTimer / BURST_DURATION, 1);
        burstingCells.forEach(([x, y, color]) => {
          drawBurstParticle(ctx, x * CELL + GRID_OFFSET_X, y * CELL + GRID_OFFSET_Y, color, progress);
        });
      }

      for (let y = 0; y < ROWS; y++) {
        for (let x = 0; x < COLS; x++) {
          if (board[y] && board[y][x]) {
            if (board[y][x] === 'obstacle') {
              // Draw obstacle block with dark borders (isObstacle=true)
              drawWrappedCandy(ctx, x * CELL + GRID_OFFSET_X, y * CELL + GRID_OFFSET_Y, '#888888', CELL, 0.7, 0, true);
            } else {
              drawPuyo(ctx, x * CELL + GRID_OFFSET_X, y * CELL + GRID_OFFSET_Y, board[y][x]);
            }
          }
        }
      }

      // Draw falling obstacle block
      if (obstacleBlock) {
        drawWrappedCandy(ctx, obstacleBlock.x * CELL + GRID_OFFSET_X, obstacleBlock.y * CELL + GRID_OFFSET_Y, '#888888', CELL, 0.7, 0, true);
      }

      if (current) {
        const px = Math.round(current.x) * CELL + GRID_OFFSET_X;
        const py = Math.floor(current.y) * CELL + GRID_OFFSET_Y;
        drawPuyo(ctx, px, py, current.colors[0]);
        const sp = getSatellitePos(current);
        drawPuyo(ctx, Math.round(sp.x) * CELL + GRID_OFFSET_X, Math.floor(sp.y) * CELL + GRID_OFFSET_Y, current.colors[1]);
      }

      if (paused && started && !gameOver) {
        ctx.fillStyle = 'rgba(255,200,220,0.7)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#ff1493';
        ctx.font = 'bold 24px Courier New';
        ctx.textAlign = 'center';
        ctx.fillText('一時停止', canvas.width / 2, canvas.height / 2);
      }

      if (gameOver) {
        ctx.fillStyle = 'rgba(255,200,220,0.85)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#ff1493';
        ctx.font = 'bold 28px Courier New';
        ctx.textAlign = 'center';
        ctx.fillText('ゲームオーバー', canvas.width / 2, canvas.height / 2);
        ctx.fillStyle = '#333';
        ctx.font = '14px Courier New';
        ctx.fillText(`スコア: ${score}`, canvas.width / 2, canvas.height / 2 + 25);
        // Restart button is shown via HTML button element
      }

      ctx.restore(); // End shake offset

      // Draw chain popup text
      if (popupAlpha > 0) {
        ctx.save();
        ctx.globalAlpha = popupAlpha;
        ctx.fillStyle = popupColor;
        ctx.shadowColor = '#fff';
        ctx.shadowBlur = 30;
        ctx.font = `bold ${Math.floor(48 * popupScale)}px Courier New`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        // Draw stroke for emphasis
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 4;
        ctx.strokeText(popupText, canvas.width / 2, canvas.height / 2 - 30);
        ctx.fillText(popupText, canvas.width / 2, canvas.height / 2 - 30);
        ctx.restore();
        popupAlpha -= 0.012;
      }
    }

    function drawNext() {
      const nextSize = Math.floor(28 * SCALE);
      const bgGrad = nextCtx.createLinearGradient(0, 0, 80, 80);
      bgGrad.addColorStop(0, '#ffd6e7');
      bgGrad.addColorStop(0.5, '#ffc8dd');
      bgGrad.addColorStop(1, '#ffe0f0');
      nextCtx.fillStyle = bgGrad;
      nextCtx.fillRect(0, 0, 80, 80);
      if (nextPuyo) {
        drawPuyo(nextCtx, 20, 8, nextPuyo.colors[0], nextSize);
        drawPuyo(nextCtx, 20, 40, nextPuyo.colors[1], nextSize);
      }
    }

    function gameLoop(time) {
      // Cap delta to prevent huge jumps on tab switch / background resume
      let delta = time - lastTime;
      if (delta > 200) delta = 16; // Treat >200ms gaps as a single frame
      lastTime = time;

      // Update all visual effects (runs even during freeze)
      updateVisualEffects(delta);

      update(delta);
      draw();
      requestAnimationFrame(gameLoop);
    }

    document.addEventListener('keydown', (e) => {
      // Initialize audio on first interaction (browser autoplay policy)
      audioManager.init();

      if (!started) {
        if (e.code === 'Space') {
          started = true;
          overlay.classList.add('hidden');
          init();
          spawn();
          clickSfx();
          startBGM();
        }
        return;
      }

      if (gameOver) {
        if (e.code === 'KeyR') {
          started = true;
          overlay.classList.add('hidden');
          init();
          spawn();
          clickSfx();
          startBGM();
        }
        return;
      }

      switch (e.code) {
        case 'ArrowLeft': tryMove(-1); break;
        case 'ArrowRight': tryMove(1); break;
        case 'ArrowDown': drop(); break;
        case 'Space': hardDrop(); break;
        case 'Period': tryRotate(1); break;
        case 'Slash': tryRotate(-1); break;
        case 'PageUp': tryRotate(1); break;
        case 'PageDown': tryRotate(-1); break;
        case 'KeyP':
          paused = !paused;
          // Mute/unmute BGM on pause (only if not globally muted)
          if (audioManager.bgmGain) {
            audioManager.bgmGain.gain.value = (paused || audioManager.muted) ? 0 : 0.15;
          }
          break;
        case 'KeyM': audioManager.toggleMute(); break;
      }

      // Update mute button icon
      const muteBtn = document.getElementById('mute-btn');
      if (muteBtn) {
        muteBtn.textContent = audioManager.muted ? '🔇' : '🔊';
      }
    });

    // Mute button click handler
    document.getElementById('mute-btn').addEventListener('click', () => {
      audioManager.init(); // Ensure audio is initialized
      audioManager.toggleMute();
      const muteBtn = document.getElementById('mute-btn');
      muteBtn.textContent = audioManager.muted ? '🔇' : '🔊';
    });

    // ===== iPad Touch Gesture Support =====
    let touchStartX = 0;
    let touchStartY = 0;
    let touchStartTime = 0;
    const SWIPE_THRESHOLD = 30;
    const TAP_THRESHOLD = 10;

    canvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      audioManager.init();
      const t = e.touches[0];
      touchStartX = t.clientX;
      touchStartY = t.clientY;
      touchStartTime = Date.now();
    }, { passive: false });

    canvas.addEventListener('touchend', (e) => {
      e.preventDefault();
      if (!started) {
        started = true;
        overlay.classList.add('hidden');
        init();
        spawn();
        clickSfx();
        startBGM();
        return;
      }

      if (gameOver) {
        started = true;
        overlay.classList.add('hidden');
        init();
        spawn();
        clickSfx();
        startBGM();
        return;
      }

      const t = e.changedTouches[0];
      const dx = t.clientX - touchStartX;
      const dy = t.clientY - touchStartY;
      const dt = Date.now() - touchStartTime;
      const absDx = Math.abs(dx);
      const absDy = Math.abs(dy);

      // Tap detection (minimal movement, quick touch)
      if (absDx < TAP_THRESHOLD && absDy < TAP_THRESHOLD && dt < 300) {
        // Tap = rotate
        tryRotate(1);
        clickSfx();
        return;
      }

      // Swipe detection
      if (absDx > absDy) {
        // Horizontal swipe
        if (absDx > SWIPE_THRESHOLD) {
          if (dx > 0) {
            tryMove(1); // Swipe right = move right
          } else {
            tryMove(-1); // Swipe left = move left
          }
        }
      } else {
        // Vertical swipe
        if (dy > SWIPE_THRESHOLD) {
          // Swipe down = hard drop with velocity-based distance
          const velocity = absDy / dt; // pixels per ms
          let dropDistance = -1; // default: drop all the way
          if (velocity < 0.5) {
            dropDistance = 1;
          } else if (velocity < 1.0) {
            dropDistance = 3;
          } else if (velocity < 2.0) {
            dropDistance = 6;
          } else {
            dropDistance = 9; // max
          }
          hardDrop(dropDistance);
        } else if (dy < -SWIPE_THRESHOLD) {
          tryRotate(1); // Swipe up = rotate
        }
      }
    }, { passive: false });

    // Prevent default touch behaviors (scrolling, zooming)
    canvas.addEventListener('gesturestart', (e) => e.preventDefault());
    canvas.addEventListener('gesturechange', (e) => e.preventDefault());
    canvas.addEventListener('gestureend', (e) => e.preventDefault());

    // ===== iPad Touch Button Controls =====
    function setupTouchButton(id, action) {
      const btn = document.getElementById(id);
      if (!btn) return;
      btn.addEventListener('touchstart', (e) => {
        e.preventDefault();
        e.stopPropagation();
